"""
Environment Configuration
Copy this to .env and fill in your values.
"""

# Django
SECRET_KEY=REPLACED_PLACEHOLDER_KEY
DEBUG=True

# Email (SMTP)
# Set EMAIL_BACKEND to smtp to use real email
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@fitnesshub.com
BASE_URL=http://localhost:8000

# SMS — Twilio (set to 'twilio' to enable)
SMS_PROVIDER=console
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_VERIFY_SERVICE_SID=
TWILIO_MESSAGING_SERVICE_SID=

# Phone formatting
DEFAULT_COUNTRY_CODE=NP

# Verification cooldown
VERIFICATION_COOLDOWN_MINUTES=1
EMAIL_VERIFICATION_REQUIRED=True

# ZeroBounce Email Verification (https://www.zerobounce.net — 100 free checks/month)
# Leave empty to fall back to MX record validation only
ZEROBOUNCE_API_KEY=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
